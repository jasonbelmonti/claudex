{
  "name": "claudex",
  "module": "index.ts",
  "packageManager": "bun@1.3.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "biome lint .",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint && bun run typecheck && bun run test",
    "ci": "bun run lint && bun run typecheck && bun run test:coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@openai/codex-sdk": "^0.112.0",
    "ajv": "^8.18.0"
  }
}

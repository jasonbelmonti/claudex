{
  "name": "@jasonbelmonti/claudex",
  "version": "1.0.0",
  "description": "Provider-agnostic normalized TypeScript interface over CLI-authenticated Claude and Codex SDKs.",
  "module": "./src/index.ts",
  "packageManager": "bun@1.3.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "homepage": "https://github.com/jasonbelmonti/claudex#readme",
  "bugs": {
    "url": "https://github.com/jasonbelmonti/claudex/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonbelmonti/claudex.git"
  },
  "keywords": [
    "agents",
    "bun",
    "claude",
    "codex",
    "sdk",
    "typescript"
  ],
  "files": [
    "src"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./ingest": "./src/ingest/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "biome lint .",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "test:smoke": "CLAUDEX_SMOKE=1 bun test ./test/smoke/codex.smoke.ts ./test/smoke/claude.smoke.ts",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint && bun run typecheck && bun run test",
    "ci": "bun run lint && bun run typecheck && bun run test:coverage",
    "package:check": "npm pack --dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@openai/codex-sdk": "^0.112.0",
    "ajv": "^8.18.0"
  }
}
